{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "node16",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"outDir": "./dist",
		"rootDir": ".",
		"types": ["node"]
	},
	"include": [
		"tests/**/*.ts",
		"tests2/**/*.ts",
		"playwright.config.ts",
		"config/config.ts"
	]
}
